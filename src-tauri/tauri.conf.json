{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SnapTeX",
  "version": "2.0.0",
  "identifier": "com.snaptex.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "SnapTeX",
        "width": 1160,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/icon.ico"
    ],
    "resources": {
      "../models/mfr-1.5-int8/*": "models/mfr-1.5-int8/"
    },
    "windows": {
      "nsis": {
        "compression": "lzma",
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false,
        "languages": [
          "SimpChinese",
          "English"
        ]
      }
    }
  }
}
